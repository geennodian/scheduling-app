generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  connectedGoogleAccounts ConnectedGoogleAccount[]
  schedulingPages SchedulingPage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ConnectedGoogleAccount {
  id              String   @id @default(cuid())
  userId          String
  googleEmail     String
  googleAccountId String
  accessToken     String   @db.Text
  refreshToken    String   @db.Text
  expiryDate      DateTime?
  scope           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendars  ConnectedCalendar[]

  @@unique([userId, googleAccountId])
}

model ConnectedCalendar {
  id                       String  @id @default(cuid())
  connectedGoogleAccountId String
  calendarId               String
  calendarName             String
  selectedForAvailability  Boolean @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  connectedGoogleAccount ConnectedGoogleAccount @relation(fields: [connectedGoogleAccountId], references: [id], onDelete: Cascade)
  schedulingPageTargets  SchedulingPageCalendarTarget[]
  assignedBookings       Booking[]
  calendarGroupMembers   CalendarGroupMember[]

  @@unique([connectedGoogleAccountId, calendarId])
}

model SchedulingPage {
  id                  String   @id @default(cuid())
  userId              String
  title               String
  description         String?  @db.Text
  organizerName       String?
  slug                String   @unique
  mode                SchedulingMode @default(COMMON_FREE)
  timezone            String   @default("Asia/Tokyo")
  dateRangeDays       Int      @default(30)
  slotMinutes         Int      @default(30)
  bufferBeforeMinutes Int      @default(0)
  bufferAfterMinutes  Int      @default(0)
  dailyLimit          Int?
  isPublished         Boolean  @default(false)
  calendarCreation    CalendarCreationMode @default(REPRESENTATIVE)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekdayRules      SchedulingPageWeekdayRule[]
  timeRules         SchedulingPageTimeRule[]
  calendarTargets   SchedulingPageCalendarTarget[]
  calendarGroups    CalendarGroup[]
  bookingFormSetting BookingFormSetting?
  bookings          Booking[]
  bookingLocks      BookingLock[]
}

enum SchedulingMode {
  COMMON_FREE
  ANY_FREE
}

enum CalendarCreationMode {
  REPRESENTATIVE
  ASSIGNED
}

model SchedulingPageWeekdayRule {
  id               String @id @default(cuid())
  schedulingPageId String
  weekday          Int    // 0=Sun, 1=Mon, ... 6=Sat
  enabled          Boolean @default(true)

  schedulingPage SchedulingPage @relation(fields: [schedulingPageId], references: [id], onDelete: Cascade)

  @@unique([schedulingPageId, weekday])
}

model SchedulingPageTimeRule {
  id               String @id @default(cuid())
  schedulingPageId String
  startTime        String // "09:00"
  endTime          String // "18:00"

  schedulingPage SchedulingPage @relation(fields: [schedulingPageId], references: [id], onDelete: Cascade)
}

model SchedulingPageCalendarTarget {
  id                  String @id @default(cuid())
  schedulingPageId    String
  connectedCalendarId String
  priorityOrder       Int    @default(0)

  schedulingPage    SchedulingPage    @relation(fields: [schedulingPageId], references: [id], onDelete: Cascade)
  connectedCalendar ConnectedCalendar @relation(fields: [connectedCalendarId], references: [id], onDelete: Cascade)

  @@unique([schedulingPageId, connectedCalendarId])
}

model CalendarGroup {
  id               String   @id @default(cuid())
  name             String
  schedulingPageId String
  priorityOrder    Int      @default(0)
  createdAt        DateTime @default(now())

  schedulingPage SchedulingPage      @relation(fields: [schedulingPageId], references: [id], onDelete: Cascade)
  members        CalendarGroupMember[]
  assignedBookings Booking[]         @relation("bookingCalendarGroup")
}

model CalendarGroupMember {
  id                  String @id @default(cuid())
  calendarGroupId     String
  connectedCalendarId String
  isRepresentative    Boolean @default(false)

  calendarGroup     CalendarGroup     @relation(fields: [calendarGroupId], references: [id], onDelete: Cascade)
  connectedCalendar ConnectedCalendar @relation(fields: [connectedCalendarId], references: [id], onDelete: Cascade)

  @@unique([calendarGroupId, connectedCalendarId])
}

model BookingFormSetting {
  id               String @id @default(cuid())
  schedulingPageId String @unique
  requireCompany   Boolean @default(false)
  requireName      Boolean @default(true)
  requireEmail     Boolean @default(true)
  requirePhone     Boolean @default(false)
  requireNote      Boolean @default(false)

  schedulingPage SchedulingPage @relation(fields: [schedulingPageId], references: [id], onDelete: Cascade)
}

model Booking {
  id                        String   @id @default(cuid())
  schedulingPageId          String
  assignedConnectedCalendarId String?
  assignedCalendarGroupId   String?
  startAt                   DateTime
  endAt                     DateTime
  companyName               String?
  personName                String
  email                     String
  phone                     String?
  note                      String?  @db.Text
  status                    BookingStatus @default(CONFIRMED)
  googleEventId             String?
  cancelToken               String?  @unique
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  schedulingPage          SchedulingPage    @relation(fields: [schedulingPageId], references: [id], onDelete: Cascade)
  assignedConnectedCalendar ConnectedCalendar? @relation(fields: [assignedConnectedCalendarId], references: [id], onDelete: SetNull)
  assignedCalendarGroup   CalendarGroup?    @relation("bookingCalendarGroup", fields: [assignedCalendarGroupId], references: [id], onDelete: SetNull)

  @@index([schedulingPageId, startAt, endAt])
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

model BookingLock {
  id               String   @id @default(cuid())
  schedulingPageId String
  slotKey          String   // "2024-01-15T09:00"
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  schedulingPage SchedulingPage @relation(fields: [schedulingPageId], references: [id], onDelete: Cascade)

  @@unique([schedulingPageId, slotKey])
  @@index([expiresAt])
}
